# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # service_role key (PRIVE, jamais cote client)

# --- Resend (envoi des emails de connexion) ---
RESEND_API_KEY=re_xxx
FROM_EMAIL=login@triskell-studio.fr
REPLY_TO_EMAIL=contact@triskell-studio.fr

# --- JWT (sessions Lanceur) ---
JWT_SECRET=change-me-32-chars-random-hex   # `openssl rand -hex 32`

# --- Public URL de cette API ---
PUBLIC_URL=https://api.triskell-studio.fr

# --- Secret partage entre les webhooks Stripe et /api/register-license ---
# Doit etre identique dans CE backend et dans landing-pack/Suite des Heros
INTERNAL_SHARED_SECRET=change-me-32-chars-random-hex

# --- Telechargement Suite des Heros ---
# Reutilise le DOWNLOAD_SIGNING_SECRET de productivite.triskell-studio.fr
# pour generer des liens de download a la volee depuis le Lanceur.
DOWNLOAD_SIGNING_SECRET=identique-a-celui-de-suite-des-heros
SUITE_DOWNLOAD_HOST=https://productivite.triskell-studio.fr
SUITE_VERSION=1.0
