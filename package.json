{
  "name": "triskell-table-ronde",
  "version": "0.1.5",
  "description": "La Table Ronde - hub desktop unifie de l'ecosysteme Triskell Studio",
  "main": "main.js",
  "author": "Triskell Studio",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@sentry/electron": "^5.5.0",
    "electron-updater": "^6.3.0"
  },
  "build": {
    "appId": "studio.triskell.tableronde",
    "productName": "La Table Ronde",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "apps.json",
      "src/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Jordan-Bourillot",
        "repo": "triskell-table-ronde"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "La Table Ronde",
      "include": "build/installer.nsh"
    }
  }
}
